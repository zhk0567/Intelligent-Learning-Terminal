.tab-lead {
  padding: 16rpx 32rpx;
  line-height: 1.5;
}

.inner-tabs {
  display: flex;
  gap: 16rpx;
  padding: 8rpx 32rpx 16rpx;
}

.inner-tab {
  padding: 12rpx 32rpx;
  border-radius: 999rpx;
  background: var(--surface);
  color: var(--on-surface-variant);
  font-size: 26rpx;
}

.inner-tab.active {
  background: var(--surface-variant);
  color: var(--primary);
  font-weight: 600;
}

.story-kw-row {
  padding: 0 32rpx 16rpx;
}

.story-kw {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--surface);
  color: var(--on-surface);
  border: 1rpx solid var(--surface-variant);
  font-size: 26rpx;
  box-sizing: border-box;
}

.no-hit {
  padding: 48rpx;
  text-align: center;
}

.story-scroll {
  padding: 0 24rpx 120rpx;
  box-sizing: border-box;
}

.story-masonry {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.story-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.story-card {
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-md);
}

.story-img {
  width: 100%;
  height: 100%;
  display: block;
}

.story-overlay {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  right: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.5);
}
