<view class="page-root {{themeClass}}">
  <view class="lead muted">输入风格、情绪、节奏参数，生成演示片段并提供试听（演示流程）。</view>
  <view class="form card-surface">
    <view class="field">
      <text class="label">风格</text>
      <input class="inp" placeholder="如：古韵、电子" bindinput="onStyle" value="{{style}}" />
    </view>
    <view class="field">
      <text class="label">情绪</text>
      <input class="inp" placeholder="如：空灵、热烈" bindinput="onMood" value="{{mood}}" />
    </view>
    <view class="field">
      <text class="label">节奏 BPM</text>
      <input class="inp" type="number" placeholder="120" bindinput="onBpm" value="{{bpm}}" />
    </view>
    <button class="btn" bindtap="onGen">生成片段</button>
    <view class="foot muted">当前为模板生成版本，后续可替换为真实模型服务。</view>
  </view>
</view>
