.music-tools {
  padding: 16rpx 32rpx 8rpx;
}

.music-search-input {
  width: 100%;
  height: 72rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-md);
  background: var(--surface);
  color: var(--on-surface);
  border: 1rpx solid var(--surface-variant);
  font-size: 28rpx;
  box-sizing: border-box;
}

.entry-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.entry-chip {
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: var(--surface-variant);
  color: var(--on-surface);
  font-size: 26rpx;
}

.no-hit {
  padding: 32rpx;
  text-align: center;
}

.banner-swiper {
  height: 360rpx;
  margin: 0 32rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.banner-slide {
  position: relative;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.banner-cap {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.65));
}

.tiles-scroll {
  width: 100%;
  white-space: nowrap;
}

.tiles-row {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 32rpx 8rpx;
}

.hot-tile {
  width: 200rpx;
  flex-shrink: 0;
  overflow: hidden;
}

.hot-img {
  width: 200rpx;
  height: 200rpx;
  display: block;
}

.hot-title {
  padding: 12rpx;
  font-size: 24rpx;
  color: var(--on-surface);
  white-space: normal;
}

.picks-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 0 32rpx 24rpx;
}

.pick-card {
  width: calc(50% - 10rpx);
  overflow: hidden;
}

.pick-img {
  width: 100%;
  height: 200rpx;
  display: block;
}

.pick-title {
  padding: 12rpx 16rpx;
  font-size: 26rpx;
  color: var(--on-surface);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 0 32rpx 24rpx;
}

.tag-chip {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  border: 1rpx solid var(--outline);
  color: var(--primary);
  font-size: 26rpx;
}

.bottom-cards {
  padding: 0 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bottom-card {
  position: relative;
  height: 240rpx;
  overflow: hidden;
}

.bottom-img {
  width: 100%;
  height: 100%;
}

.bottom-cap {
  position: absolute;
  left: 24rpx;
  bottom: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.6);
}
