.hero {
  width: 100%;
  height: 320rpx;
  display: block;
}

.body {
  margin: -36rpx 24rpx 48rpx;
  padding: 28rpx;
}

.badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: var(--surface-variant);
  color: var(--primary);
  font-size: 22rpx;
}

.t {
  margin-top: 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.block {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.5;
}

.block.small {
  font-size: 24rpx;
}

.subh {
  margin: 28rpx 0 12rpx;
  font-size: 24rpx;
  color: var(--primary);
}

.goal {
  font-size: 26rpx;
  color: var(--on-surface-variant);
  padding: 6rpx 0;
}

.btn {
  margin-top: 32rpx;
  background: var(--surface-variant);
  color: var(--primary);
  font-size: 28rpx;
}

.empty {
  padding: 80rpx 32rpx;
  text-align: center;
}
