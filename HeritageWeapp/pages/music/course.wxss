.sub-hint {
  padding: 24rpx 32rpx;
  font-size: 26rpx;
}

.list {
  padding: 0 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.course-card {
  overflow: hidden;
}

.course-cover {
  width: 100%;
  height: 240rpx;
  display: block;
}

.course-body {
  padding: 24rpx;
}

.course-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--on-surface);
}

.course-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.course-sum {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: var(--on-surface-variant);
  line-height: 1.5;
}
